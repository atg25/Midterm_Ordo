# Copy values into your shell environment (recommended) or local env manager.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_REQUEST_TIMEOUT_MS=10000
ANTHROPIC_RETRY_ATTEMPTS=2
ANTHROPIC_RETRY_DELAY_MS=150
# Legacy-compatible names (optional)
API__ANTHROPIC_API_KEY=
API__ANTHROPIC_MODEL=claude-haiku-4-5
API__ANTHROPIC_REQUEST_TIMEOUT_MS=10000
API__ANTHROPIC_RETRY_ATTEMPTS=2
API__ANTHROPIC_RETRY_DELAY_MS=150

# Optional Gary's events MCP bridge settings (Midterm subprocess integration)
GARYS_EVENTS_MCP_ENABLED=true
GARYS_EVENTS_MCP_FAIL_OPEN=true
GARYS_EVENTS_CHAT_DOT_NAME_COMPATIBLE=false
GARYS_EVENTS_MCP_REPO_PATH=../PyPack_GarysGuide
GARYS_EVENTS_MCP_MODULE=garys_nyc_events.mcp.server
GARYS_EVENTS_MCP_STARTUP_TIMEOUT_MS=8000
GARYS_EVENTS_MCP_STARTUP_RETRY_ATTEMPTS=1
GARYS_EVENTS_MCP_STARTUP_RETRY_DELAY_MS=250
GARYS_EVENTS_REST_API_BASE_URL=
GARYS_EVENTS_REST_API_TIMEOUT_MS=10000

# Optional ph_ai_tracker (Product Hunt AI tracker) integration settings
WEBSCRAPER_MCP_ENABLED=false
WEBSCRAPER_MCP_FAIL_OPEN=true
WEBSCRAPER_CHAT_DOT_NAME_COMPATIBLE=false
WEBSCRAPER_MCP_REPO_PATH=../ph_ai_tracker
WEBSCRAPER_MCP_MODULE=ph_ai_tracker.api
WEBSCRAPER_MCP_STARTUP_TIMEOUT_MS=8000
WEBSCRAPER_MCP_STARTUP_RETRY_ATTEMPTS=1
WEBSCRAPER_MCP_STARTUP_RETRY_DELAY_MS=250
# Example: http://localhost:8000
WEBSCRAPER_REST_API_BASE_URL=
WEBSCRAPER_REST_API_TOKEN=
WEBSCRAPER_REST_API_TIMEOUT_MS=10000
